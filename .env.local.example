# ─────────────────────────────────────────────────────────────────────────────
# NextGen-UMPSA — Environment Variables
# Copy this file to .env.local and fill in your values
# ─────────────────────────────────────────────────────────────────────────────

# ── Gemini AI ────────────────────────────────────────────────────────────────
# Required for AI Coach chat responses and function calling.
# Get your key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# ── Database (PostgreSQL) ───────────────────────────────────────────────────
# Required for chat logging / audit trail.
# Format: postgres://user:password@host:5432/database
# Leave empty to disable chat logging (dev/static mode).
DATABASE_URL=

# ── Base Path ───────────────────────────────────────────────────────────────
# Leave empty for local dev. Set by CI for GitHub Pages deployment.
NEXT_PUBLIC_BASE_PATH=
